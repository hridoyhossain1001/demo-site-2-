# Load these values only for a controlled staging deployment.
# Never point STAGING_SSH_HOST at the active DO_SSH_HOST.

STAGING_SSH_HOST=staging.example.com
STAGING_SSH_USER=deploy
STAGING_REMOTE_DIR=/var/www/buykori-adsync
STAGING_SSH_KNOWN_HOSTS=
STAGING_BASE_URL=https://staging-api.example.com

# Set only after the companion portal/plugin releases are ready on staging.
STAGING_DEPLOY_CONFIRM=staging
PORTAL_RELEASE_CONFIRM=csrf-wrapper
PLUGIN_RELEASE_CONFIRM=capi-signing-secret

# Needed only by scripts/ops/staging_smoke_check.py.
ADMIN_API_KEY=
